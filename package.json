    "deploy-godot-addon": "ts-node ./scripts/godot-addon.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.5.2",
    "astro": "^5.16.3",
    "fast-xml-parser": "^5.2.5",
    "fs-extra": "^11.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "private": true,
  "main": "index.js",
  "license": "MIT"
}
