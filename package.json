{
  "name": "folded-paper-engine",
  "version": "1.0.0",
  "description": "Folded Paper Engine",
  "scripts": {
    "dev:web": "astro dev",
    "build:web": "astro build",
    "preview:web": "astro preview",
    "deploy-website": "rm -rf ./dist && mkdir -p dist && cp -a src/website/* dist && cp ./CNAME ./dist/CNAME",
    "deploy-docs": "yarn deploy-godot-addon-docs",
