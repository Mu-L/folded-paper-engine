---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout title="YouTube Tutorials">
    <section
            class="web-splash"
    >
        <div
                class="web-splash-inner video-box"
        >
            <iframe
                    width="100%"
                    height="720"
                    src="https://www.youtube.com/embed/videoseries?list=PLM1XlwxBilobr6XVs-7H6O_mMXAiHZEcz"
                    title="YouTube playlist player"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen>
            </iframe>
        </div>
    </section>
    <section
            class="section top-section"
    >
    </section>
</SiteLayout>
