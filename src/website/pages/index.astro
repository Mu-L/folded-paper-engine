---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
        title="Home"
>
    <Fragment slot="head">
        <script type="module" src="assets/js/index.js" is:inline></script>
    </Fragment>

    <section
            class="web-splash"
    >
        <div
                class="web-splash-inner base-background"
        >
            <img class="web-splash-img index-web-splash" src="assets/images/web-splash.png" alt="Splash">
            <img class="apple-sticker" src="assets/images/apple-sticker.png" alt="Apple Sticker">
            <img class="star-sticker" src="assets/images/splash-star.png" alt="Star Sticker">
            <button class="demo-button button red">
                Play the Demo!
                <img class="button-icon" src="assets/images/mug-icon.png" alt="A latte in a small, white coffee mug">
            </button>
        </div>
    </section>
    <section
            class="section top-section"
    >
        <header>
            <img class="title-graphic" src="assets/images/doc-owl.png" alt="A brown owl holding a document">
            <div
                    class="section-title"
            >
                Get Wise!
                <div class="section-subtitle">
                    Docs & More...
                </div>
            </div>
        </header>
        <main>
            <a class="button" href="./blender-panel-docs.html">
                Blender Panels
                <img class="button-icon" src="assets/images/blender-logo-icon.png" alt="Blender Logo">
            </a>
            <div
                    class="stack"
            >
                <a class="button" href="./godot-feature-docs.html">
                    Godot Features
                    <img class="button-icon" src="assets/images/godot-logo-icon.png" alt="Godot Logo">
                </a>
                <a class="stack-link" href="./godot-api-docs">
                    Godot API
                </a>
            </div>
            <a class="button" href="./youtube-tutorials.html">
                Tutorials
                <img class="button-icon" src="assets/images/youtube-logo-small.png" alt="YouTube Logo">
            </a>
            <a class="button" href="./docs/folded-paper-engine-guide.html">
                Engine Guide
                <img class="button-icon" src="assets/images/guide-icon.png" alt="Folded Paper Engine guide owl">
            </a>
        </main>
    </section>
    <section
            id="download"
            class="section"
    >
        <header class="flipped">
            <img class="title-graphic" src="assets/images/dl-backpack.png" alt="A red backpack">
            <div
                    class="section-title"
            >
                Pack for Your Adventure...
                <div class="section-subtitle">
                    Download Now!
                </div>
            </div>
        </header>
        <main>
            <a class="button blue blender-download"
               href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine.zip">
                Download for Blender 4.4+
                <img class="button-icon" src="assets/images/blender-logo-icon.png" alt="Blender Logo">
            </a>
            <a class="button blue godot-download"
               href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine_godot.zip">
                Download for Godot 4.4+
                <img class="button-icon" src="assets/images/godot-logo-icon.png" alt="Godot Logo">
            </a>
        </main>
        <div class="spacer section-spacer"></div>
        <main>
            <div class="stack">
                <a
                        class="button stack-link"
                        href="https://github.com/papercraftgames/folded-paper-engine/releases"
                        target="_blank"
                >
                    Previous Versions
                </a>
            </div>
        </main>
    </section>
</SiteLayout>
