    <section class="web-splash">
        <div class="web-splash-inner base-background">
            <img
                    class="web-splash-img"
                    src="/assets/images/home-splash.png"
                    alt="Folded Paper Engine Splash"
            />
        </div>
    </section>

    <section class="section top-section" id="download">
        <!-- your existing hero / download cards / etc from index.html go here -->
    </section>

    <!-- more sections... -->
</SiteLayout>
