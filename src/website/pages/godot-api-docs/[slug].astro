---
import GodotApiLayout from "../../layouts/GodotAPILayout.astro";
import {loadGodotApiPages, type GodotApiPage} from "../../godotApiDocs";

export async function getStaticPaths() {
  const pages = await loadGodotApiPages();
  return pages.map((p) => ({
    params: {slug: p.slug},
    props: {page: p},
  }));
}

const {page} = Astro.props as { page: GodotApiPage };
---

<GodotApiLayout title={page.title}>
    <a href="../">
        <button class="button blue">&lt; Back</button>
    </a>
    <article class="api-doc-article">
        <div class="api-doc-body" set:html={page.bodyHtml}/>
    </article>
</GodotApiLayout>
