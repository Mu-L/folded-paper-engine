---
/**
  * FeaturedOnGameFromScratch
  */
---

<section class="press-coverage-section" aria-label="Press coverage">
    <div class="gfs-card">
        <header class="gfs-header">
            <span aria-hidden="true">⭐️</span>

            <div class="gfs-text">
                <h3>Featured on GameFromScratch</h3>
                <p>A full tutorial video and write-up</p>
            </div>
        </header>

        <nav class="gfs-actions">
            <a
                    href="https://youtu.be/YW5N8ANrm9c?si=cr1RFxQvIf4vPdPf"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="button medium"
            >
                ▶ Watch the video
            </a>

            <a
                    href="https://gamefromscratch.com/folded-paper-engine-blender-to-godot"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="button medium"
            >
                📝 Read the article
            </a>
        </nav>
    </div>
</section>

<style>
    .press-coverage-section {
        background-color: #e28903;
        margin: 0 0 0 0;
        padding: 1em;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #ffffff;
    }

    .gfs-card {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        justify-content: center;

        margin: 2em auto;
        padding: 1.1em 1.4em;

        background-color: #ffc100;
        border: 0.2em solid rgba(255, 255, 255, 0.35);
        border-radius: 1.1em;

        box-shadow: 0 0.75em 1.5em rgba(0, 0, 0, 0.12);
        backdrop-filter: blur(0.5em);
    }

    .gfs-header {
        display: flex;
        align-items: center;
        gap: 0.75em;
        margin-bottom: 0.75em;
        font-size: 2em;

        @media screen and (max-width: 768px) {
            font-size: 1.5em;
        }
    }

    .gfs-icon {
        width: 2.2em;
        height: 2.2em;
        border-radius: 0.75em;

        display: grid;
        place-items: center;

        background: rgba(0, 0, 0, 0.18);
        font-size: 1.1em;
    }

    .gfs-text h3 {
        margin: 0;
        font-size: 1em;
    }

    .gfs-text p {
        font-family: sans-serif;
        margin: 0.25em 0 0;
        font-size: 0.75em;
        opacity: 0.9;
    }

    .gfs-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.6em;

        @media screen and (max-width: 768px) {
            flex-direction: column;
        }
    }
</style>
